{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/index.js"
    },
    {
      "src": "/(css|js|assets|uploads)/(.*)",
      "dest": "/$1/$2",
      "continue": true
    },
    {
      "src": "/(.*)",
      "dest": "server/index.js"
    }
  ]
}